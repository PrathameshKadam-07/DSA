package StringEasy;

public class StringIntegeratoi {
	
    public int myAtoi(String s) {
       String st = s.trim();
       int sign = 1;
       int num=0;
       		if(st.charAt(0) == '-') {
       				sign = -1;
       				for(int i = 1;i<s.length();i++) {
       		if((st.charAt(i)-'0') > 0 && (st.charAt(i)-'0') <=9) {
    			   num = (num*10)+(st.charAt(i) - '0');   
    		   }
    		   else {
    			   num=num*sign;
    			   return num;
    			   
    			   
    		   }
    	   }
       }
       else if(st.charAt(0) == '+') {
    	   for(int i = 1;i<s.length();i++) {
    		   if((st.charAt(i)-'0') > 0 && (st.charAt(i)-'0') <=9) {
    			   num = (num*10)+(st.charAt(i) - '0');
    			   
    		   }
    		   else {
    			   num=num*sign;
    			   return num; 
    		   }
    	   }}
    	  
       else if((st.charAt(0)-'0') > 0 && (st.charAt(0)-'0') <=9) {
    	   for(int i = 1;i<s.length();i++) {
    		   if((st.charAt(i)-'0') > 0 && (st.charAt(i)-'0') <=9) {
    			   num = (num*10)+(st.charAt(i) - '0');
    			   
    		   }
    		   else {
    			   num=num*sign;
    			   return num;
    		   }
    	   	}
       }
    	   else {
    		 return 0;
    	   }
       		
			return num;
    }
public static void main(String[] args) {
	String s = "42";
	StringIntegeratoi s1 = new StringIntegeratoi();
	
	System.out.println(s1.myAtoi(s));
}
}
