package Recursion;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.Collections;

class pb_21 {
    public static ArrayList<Integer> mergeTwoLists(ArrayList<Integer> list1, ArrayList<Integer> list2,int len1,int len2) {
        ArrayList l = new ArrayList<Integer>();
        l.add(list1.get(len1-1));
        l.add(list2.get(len2-1));
        mergeTwoLists(list1, list2, len1-1, len2-1);
        Collections.sort(l);
        return l;
    }
    
    public static void main(String[] args) {
		ArrayList<Integer> l1 = new ArrayList<Integer>(Arrays.asList(1,1,2,3));
		ArrayList<Integer> l2 = new ArrayList<Integer>(Arrays.asList(1,4,5));
		int len1 = l1.size();
		int len2 = l2.size();
		System.out.println(mergeTwoLists(l1,l2,len1,len2));
	}
}
